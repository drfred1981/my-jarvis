# Discord
DISCORD_BOT_TOKEN=
DISCORD_CHANNEL_IDS=          # Comma-separated channel IDs (optional, empty = all)

# Home Assistant
HA_URL=http://homeassistant.default.svc.cluster.local:8123
HA_TOKEN=

# Git repositories (JSON dict: {"alias": "url", ...})
GIT_REPOS={"infra":"https://github.com/username/home-k8s-infra.git","apps":"https://github.com/username/home-k8s-apps.git","jarvis":"https://github.com/username/my-jarvis.git"}
GITHUB_TOKEN=

# Grafana / Prometheus
GRAFANA_URL=http://grafana.monitoring.svc.cluster.local:3000
GRAFANA_TOKEN=
PROMETHEUS_URL=http://prometheus.monitoring.svc.cluster.local:9090

# Planka (project management)
PLANKA_URL=http://planka.default.svc.cluster.local:1337
PLANKA_USER=
PLANKA_PASSWORD=

# Miniflux (RSS reader)
MINIFLUX_URL=http://miniflux.default.svc.cluster.local:8080
MINIFLUX_API_KEY=

# Immich (photos)
IMMICH_URL=http://immich.default.svc.cluster.local:2283
IMMICH_API_KEY=

# Karakeep (bookmarks)
KARAKEEP_URL=http://karakeep.default.svc.cluster.local:3000
KARAKEEP_API_KEY=

# DocMost (wiki) - API key (enterprise) OR user/password (self-hosted)
DOCMOST_URL=
DOCMOST_API_KEY=              # Enterprise edition only
DOCMOST_USER=                 # Email for login auth (alternative to API key)
DOCMOST_PASSWORD=             # Password for login auth

# Music Assistant
MUSIC_ASSISTANT_URL=http://music-assistant.default.svc.cluster.local:8095

# Synology Chat (optional)
SYNOLOGY_CHAT_WEBHOOK_URL=

# Synology Router (optional)
SRM_URL=
SRM_USER=
SRM_PASSWORD=

# Plex (optional)
PLEX_URL=
PLEX_TOKEN=

# Homebox (home inventory, optional)
HOMEBOX_URL=
HOMEBOX_USER=
HOMEBOX_PASSWORD=

# LubeLogger (vehicle maintenance, optional)
LUBELOG_URL=
LUBELOG_API_KEY=

# Gatus (status page)
GATUS_URL=
GATUS_USER=                   # Optional, for protected endpoints
GATUS_PASSWORD=               # Optional, for protected endpoints

# MIND (reminders/notifications, optional)
MIND_URL=
MIND_USER=
MIND_PASSWORD=

# Jarvis limits
JARVIS_MAX_BUDGET=1.00        # Max USD per request
JARVIS_MAX_TURNS=10           # Max agentic turns per request

# Proactive monitoring
JARVIS_MONITORING=true        # Enable/disable periodic health checks

# Environment
ENV=development
